{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "geodatos",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/distritos-madrid.geojson",
          "/barrios-madrid.geojson"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/manifest.webmanifest"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "photon",
      "urls": ["https://photon.komoot.io/**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 50,
        "maxAge": "1d"
      }
    },
    {
      "name": "nominatim",
      "urls": ["https://nominatim.openstreetmap.org/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "1d",
        "timeout": "5s"
      }
    },
    {
      "name": "osm-tiles",
      "urls": ["https://*.tile.openstreetmap.org/**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 100,
        "maxAge": "7d"
      }
    }
  ]
}
